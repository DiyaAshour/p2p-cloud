# Chunknet / p2p-cloud environment example
# Copy this file to .env locally, then fill real values on your machine or server.
# Never commit .env files or real secrets.

# -----------------------------
# Manifest Sync
# -----------------------------
# Client URL used by Electron to push/pull manifests.
P2P_MANIFEST_SYNC_URL=http://YOUR_SERVER_IP:8790
MANIFEST_SYNC_URL=http://YOUR_SERVER_IP:8790

# Required for POST/DELETE manifest sync auth.
# Must be the same value on Electron clients and the manifest-sync server.
# Use a long random secret, for example 32+ bytes.
P2P_MANIFEST_SYNC_AUTH_SECRET=replace-with-long-random-secret
MANIFEST_SYNC_AUTH_SECRET=replace-with-long-random-secret

# Server options.
MANIFEST_SYNC_HOST=0.0.0.0
MANIFEST_SYNC_PORT=8790
MANIFEST_SYNC_REQUIRE_AUTH=true
MANIFEST_SYNC_DB_FILE=./manifests.json
MANIFEST_SYNC_AUTH_MAX_AGE_MS=300000
MANIFEST_SYNC_JSON_LIMIT=25mb

# -----------------------------
# P2P Transport / Discovery
# -----------------------------
P2P_NODE_ID=
P2P_TRANSPORT_HOST=0.0.0.0
P2P_TRANSPORT_PORT=8787
P2P_PUBLIC_URL=ws://YOUR_LAN_OR_PUBLIC_IP:8787
P2P_BOOTSTRAP_URL=ws://YOUR_SERVER_IP:8788
P2P_BOOTSTRAP_HOST=0.0.0.0
P2P_BOOTSTRAP_PORT=8788
P2P_BOOTSTRAP_MAX_PEERS=5000
P2P_BOOTSTRAP_RESPONSE_LIMIT=64
P2P_BOOTSTRAP_MESSAGES_PER_MINUTE=120
P2P_BOOTSTRAP_PEER_TTL_MS=600000
P2P_BOOTSTRAP_MAX_PAYLOAD_BYTES=65536
P2P_BOOTSTRAP_MAX_PEER_ID_LENGTH=128
P2P_BOOTSTRAP_MAX_URL_LENGTH=256
P2P_CHUNK_STORE_DIR=
P2P_CHUNK_SIZE_BYTES=2097152
P2P_TARGET_REPLICAS=4
P2P_REPLICATION_FACTOR=4
P2P_UPLOAD_MIN_CONFIRMED_REPLICAS=3
P2P_UPLOAD_MAX_REPLICA_ATTEMPTS=8
P2P_CHUNK_STORE_ACK_TIMEOUT_MS=7000

# -----------------------------
# Storage Peer
# -----------------------------
STORAGE_PEER_HOST=0.0.0.0
STORAGE_PEER_PORT=8792
STORAGE_PEER_DATA_DIR=./storage-peer-data
STORAGE_PEER_MAX_CHUNK_BYTES=2097152
STORAGE_PEER_MAX_MESSAGE_BYTES=3055616
STORAGE_PEER_MAX_PUTS_PER_MINUTE=240
STORAGE_PEER_MAX_GETS_PER_MINUTE=600
STORAGE_PEER_MAX_DELETES_PER_MINUTE=60
# Required before chunk:delete is allowed. Leave empty to disable remote chunk deletes.
STORAGE_PEER_ADMIN_TOKEN=

# -----------------------------
# Safety Peer
# -----------------------------
P2P_SAFETY_PEER_URL=
P2P_SAFETY_PEER_MODE=emergency
P2P_SAFETY_PEER_DELETE_TOKEN=

# -----------------------------
# Protection / Repair
# -----------------------------
P2P_AUTO_REPAIR_INTERVAL_MS=10800000
P2P_AUTO_REPAIR_START_DELAY_MS=300000
P2P_PROTECTION_RETRY_INTERVAL_MS=300000
P2P_PROTECTION_RETRY_START_DELAY_MS=45000
P2P_TOMBSTONE_APPLY_INTERVAL_MS=60000

# -----------------------------
# WalletConnect / Payments
# -----------------------------
VITE_WALLETCONNECT_PROJECT_ID=replace-with-walletconnect-project-id
PAYPAL_ENV=sandbox
PAYPAL_CHECKOUT_HOST=0.0.0.0
PAYPAL_CHECKOUT_PORT=8791
PAYPAL_CLIENT_ID=replace-with-paypal-client-id
PAYPAL_CLIENT_SECRET=replace-with-paypal-client-secret
PAYPAL_RETURN_URL=http://127.0.0.1:8791/paypal/return
PAYPAL_CANCEL_URL=http://127.0.0.1:8791/paypal/cancel
# Must be identical in Electron runtime and PayPal checkout server.
# Required to unlock paid plans after PayPal/contract verification.
P2P_PLAN_UNLOCK_SECRET=replace-with-long-random-plan-unlock-secret
PLAN_UNLOCK_SECRET=replace-with-long-random-plan-unlock-secret
