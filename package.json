{
  "name": "p2p-cloud",
  "version": "1.0.0",
  "description": "A wallet-based P2P cloud storage desktop app with encrypted chunks, peer discovery, and manifest sync.",
  "author": "Diya Ashour",
  "type": "module",
  "license": "MIT",
  "scripts": {
    "dev": "vite --host 127.0.0.1 --port 3000",
    "paypal:server": "node server/paypal-checkout.js",
    "repair:manifests": "node scripts/repair-encrypted-manifests.js && node scripts/remove-bad-encrypted-manifests.js",
    "prestart:electron": "node scripts/repair-encrypted-manifests.js && node scripts/remove-bad-encrypted-manifests.js",
    "dev:electron": "concurrently \"pnpm dev\" \"pnpm paypal:server\" \"powershell -NoProfile -Command Start-Sleep -Seconds 3; node scripts/repair-encrypted-manifests.js; node scripts/remove-bad-encrypted-manifests.js; electron .\"",
    "electron:dev": "concurrently \"pnpm dev\" \"pnpm paypal:server\" \"powershell -NoProfile -Command Start-Sleep -Seconds 3; node scripts/repair-encrypted-manifests.js; node scripts/remove-bad-encrypted-manifests.js; electron .\"",
    "build": "vite build",
    "build:electron": "vite build && electron-builder",
    "electron:build": "pnpm build && electron-builder",
    "start": "pnpm prestart:electron && electron .",
    "sync:manifests": "node server/manifest-sync.js",
    "storage:peer": "node server/storage-peer.js",
    "repair:electron": "node node_modules/electron/install.js",
    "check": "tsc --noEmit",
    "format": "prettier --write .",
    "test": "vitest run"
  },
  "dependencies": {
    "@radix-ui/react-checkbox": "^1.3.3",
    "@radix-ui/react-dialog": "^1.1.15",
    "@radix-ui/react-label": "^2.1.7",
    "@radix-ui/react-slot": "^1.2.3",
    "@radix-ui/react-tabs": "^1.1.13",
    "@radix-ui/react-tooltip": "^1.2.8",
    "@walletconnect/modal": "^2.7.0",
    "@walletconnect/sign-client": "^2.21.0",
    "abitype": "^1.1.0",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "concurrently": "^8.0.0",
    "lucide-react": "^0.453.0",
    "next-themes": "^0.4.6",
    "react": "^19.2.1",
    "react-dom": "^19.2.1",
    "sonner": "^2.0.7",
    "tailwind-merge": "^3.3.1",
    "tailwindcss-animate": "^1.0.7",
    "tw-animate-css": "^1.4.0",
    "viem": "^2.43.1",
    "ws": "^8.18.0"
  },
  "devDependencies": {
    "@tailwindcss/typography": "^0.5.15",
    "@tailwindcss/vite": "^4.1.3",
    "@types/node": "^20.0.0",
    "@types/react": "^19.2.1",
    "@types/react-dom": "^19.2.1",
    "@vitejs/plugin-react": "^5.0.4",
    "autoprefixer": "^10.4.20",
    "electron": "^28.0.0",
    "electron-builder": "^24.6.0",
    "postcss": "^8.4.47",
    "prettier": "^3.6.2",
    "tailwindcss": "^4.1.14",
    "typescript": "5.9.3",
    "vite": "^5.0.0",
    "vitest": "^2.1.4"
  },
  "main": "electron/main-wrapper.js",
  "homepage": "./",
  "pnpm": {
    "onlyBuiltDependencies": [
      "electron",
      "esbuild"
    ]
  },
  "build": {
    "appId": "cloud.p2p.app",
    "productName": "p2p.cloud",
    "artifactName": "p2p-cloud-${version}-setup.${ext}",
    "files": [
      "dist/**/*",
      "electron/**/*",
      "assets/**/*",
      "node_modules/**/*",
      "server/paypal-checkout.js"
    ],
    "directories": {
      "buildResources": "assets"
    },
    "win": {
      "target": "nsis",
      "icon": "assets/icon.ico"
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true,
      "shortcutName": "p2p.cloud",
      "uninstallDisplayName": "p2p.cloud"
    }
  }
}
