{
  "name": "chunknet",
  "version": "1.0.0",
  "description": "Chunknet is a wallet-based P2P cloud storage desktop app with encrypted chunks, peer discovery, and manifest sync.",
  "author": "Diya Ashour",
  "type": "module",
  "license": "MIT",
  "scripts": {
    "dev": "node scripts/patch-upgrade-paypal-ui.cjs && vite --host 127.0.0.1 --port 3000",
    "dev:electron": "node scripts/patch-upgrade-paypal-ui.cjs && pnpm run apply:download-streaming && pnpm run apply:seed-account && pnpm run apply:seed-ui && concurrently \"pnpm dev\" \"pnpm paypal:server\" \"electron .\"",
    "electron:dev": "node scripts/patch-upgrade-paypal-ui.cjs && pnpm run apply:download-streaming && pnpm run apply:seed-account && pnpm run apply:seed-ui && concurrently \"pnpm dev\" \"pnpm paypal:server\" \"electron .\"",
    "start": "node scripts/patch-upgrade-paypal-ui.cjs && pnpm run apply:download-streaming && pnpm run apply:seed-account && pnpm run apply:seed-ui && electron .",
    "build": "node scripts/patch-upgrade-paypal-ui.cjs && vite build",
    "build:electron": "node scripts/patch-upgrade-paypal-ui.cjs && pnpm run apply:download-streaming && pnpm run apply:seed-account && pnpm run apply:seed-ui && vite build && electron-builder",
    "electron:build": "node scripts/patch-upgrade-paypal-ui.cjs && pnpm run apply:seed-account && pnpm run apply:seed-ui && pnpm build && electron-builder",
    "check": "node scripts/patch-upgrade-paypal-ui.cjs && pnpm run apply:seed-account && pnpm run apply:seed-ui && tsc -p tsconfig.json --noEmit --target ES2020 --downlevelIteration",
    "test": "vitest run",
    "format": "prettier --write .",
    "paypal:server": "node server/paypal-checkout.js",
    "sync:manifests": "node server/manifest-sync.js",
    "storage:peer": "node server/storage-peer.js",
    "stress:p2p": "node scripts/stress-p2p-bootstrap.mjs",
    "stress:p2p:malicious": "node scripts/stress-p2p-malicious.mjs",
    "stress:p2p:transfer": "node scripts/stress-p2p-transfer.mjs",
    "maintenance": "pnpm repair:manifests",
    "repair:manifests": "node scripts/repair-encrypted-manifests.js && node scripts/remove-bad-encrypted-manifests.js",
    "repair:electron": "node node_modules/electron/install.js",
    "apply:download-streaming": "node scripts/apply-download-streaming-to-path.cjs",
    "apply:seed-account": "node scripts/enable-seed-account.cjs",
    "apply:seed-ui": "node scripts/patch-seed-account-ui.cjs",
    "apply:drive-ui": "echo Drive UI integrated in NativeP2PAppLive.tsx",
    "fix:commercial": "node scripts/fix-commercial-critical-issues.cjs && node scripts/patch-native-ui-upload-streaming.cjs && node scripts/fix-native-upload-button.cjs",
    "patch:ui-upload": "pnpm run fix:commercial"
  },
  "dependencies": {
    "@adraffy/ens-normalize": "^1.11.1",
    "@noble/curves": "^1.9.7",
    "@noble/hashes": "^1.8.0",
    "@radix-ui/react-checkbox": "^1.3.3",
    "@radix-ui/react-dialog": "^1.1.15",
    "@radix-ui/react-label": "^2.1.7",
    "@radix-ui/react-slot": "^1.2.3",
    "@radix-ui/react-tabs": "^1.1.13",
    "@radix-ui/react-tooltip": "^1.2.8",
    "@scure/base": "^1.2.6",
    "@scure/bip32": "^1.7.0",
    "@scure/bip39": "^1.6.0",
    "@walletconnect/core": "^2.21.0",
    "@walletconnect/modal": "^2.7.0",
    "@walletconnect/sign-client": "^2.21.0",
    "@walletconnect/types": "^2.21.0",
    "@walletconnect/utils": "^2.21.0",
    "abitype": "^1.1.0",
    "base64-js": "^1.5.1",
    "bn.js": "^5.2.2",
    "buffer": "^6.0.3",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "concurrently": "^8.0.0",
    "eventemitter3": "^5.0.1",
    "isows": "^1.0.7",
    "lucide-react": "^0.453.0",
    "next-themes": "^0.4.6",
    "ox": "^0.9.6",
    "react": "^19.2.1",
    "react-dom": "^19.2.1",
    "rpc-websockets": "^9.1.3",
    "sonner": "^2.0.7",
    "tailwind-merge": "^3.3.1",
    "tailwindcss-animate": "^1.0.7",
    "tw-animate-css": "^1.4.0",
    "viem": "^2.43.1",
    "ws": "^8.18.0"
  },
  "devDependencies": {
    "@tailwindcss/typography": "^0.5.15",
    "@tailwindcss/vite": "^4.1.3",
    "@types/bn.js": "^5.2.0",
    "@types/node": "^20.0.0",
    "@types/react": "^19.2.1",
    "@types/react-dom": "^19.2.1",
    "@vitejs/plugin-react": "^5.0.4",
    "autoprefixer": "^10.4.20",
    "electron": "^28.0.0",
    "electron-builder": "^24.6.0",
    "postcss": "^8.4.47",
    "prettier": "^3.6.2",
    "tailwindcss": "^4.1.14",
    "typescript": "5.9.3",
    "vite": "^5.0.0",
    "vitest": "^2.1.4"
  },
  "main": "electron/main-wrapper.js",
  "homepage": "./",
  "pnpm": { "onlyBuiltDependencies": ["electron", "esbuild"] },
  "build": {
    "appId": "io.chunknet.app",
    "productName": "Chunknet",
    "artifactName": "Chunknet-${version}-setup.${ext}",
    "files": ["dist/**/*", "electron/**/*", "assets/**/*", "node_modules/**/*", "server/paypal-checkout.js"],
    "directories": { "buildResources": "assets" },
    "win": { "target": "nsis", "icon": "assets/icon.ico" },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true,
      "shortcutName": "Chunknet",
      "uninstallDisplayName": "Chunknet",
      "license": "build/license.txt"
    }
  }
}
