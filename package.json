{
  "name": "chunknet",
  "version": "1.0.0",
  "description": "Chunknet is a wallet-based P2P cloud storage desktop app with encrypted chunks, peer discovery, and manifest sync.",
  "author": "Diya Ashour",
  "type": "module",
  "license": "MIT",
  "scripts": {
    "prepare:final": "node scripts/verify-runtime.cjs",
    "verify": "node scripts/verify-runtime.cjs",
    "verify:company": "node scripts/verify-company-drive-live-contract.cjs",
    "health": "node scripts/full-health-check.cjs",
    "health:deep": "node scripts/full-health-check.cjs --deep",
    "dev": "vite --host 127.0.0.1 --port 3000",
    "dev:fast": "vite --host 127.0.0.1 --port 3000",
    "dev:renderer": "vite --host 127.0.0.1 --port 3000",
    "electron:dev": "concurrently \"pnpm dev:renderer\" \"pnpm paypal:server\" \"node scripts/launch-electron.cjs\"",
    "electron:dev:fast": "concurrently \"pnpm dev:renderer\" \"pnpm paypal:server\" \"node scripts/launch-electron.cjs\"",
    "dev:electron": "pnpm run electron:dev",
    "dev:electron:fast": "pnpm run electron:dev:fast",
    "start": "pnpm run electron:dev",
    "start:fast": "pnpm run electron:dev:fast",
    "renderer:build": "pnpm run prepare:final && vite build",
    "build": "pnpm run package:win",
    "build:fast": "vite build",
    "package:dir": "pnpm run renderer:build && node scripts/package-win.cjs --dir",
    "package:win": "pnpm run renderer:build && node scripts/package-win.cjs",
    "dist": "pnpm run package:win",
    "test": "vitest run",
    "format": "prettier --write .",
    "paypal:server": "node server/paypal-checkout.js",
    "sync:manifests": "node server/manifest-sync.js",
    "storage:peer": "node server/storage-peer.js",
    "repair:electron": "node node_modules/electron/install.js",
    "apply:download-streaming": "node scripts/apply-download-streaming-to-path.cjs && node scripts/fix-streaming-final-script-syntax.cjs && node scripts/patch-streaming-upload-download-final.cjs",
    "apply:seed-account": "node scripts/enable-seed-account.cjs",
    "apply:seed-session": "node scripts/patch-seed-session-cache.cjs && node scripts/patch-main-seed-session-read.cjs",
    "patch:folder-actions": "pnpm run prepare:final"
  },
  "dependencies": {
    "@adraffy/ens-normalize": "^1.11.1",
    "@noble/curves": "^1.9.7",
    "@noble/hashes": "^1.8.0",
    "@phc/format": "^1.0.0",
    "@radix-ui/react-checkbox": "^1.3.3",
    "@radix-ui/react-dialog": "^1.1.15",
    "@radix-ui/react-label": "^2.1.7",
    "@radix-ui/react-slot": "^1.2.3",
    "@radix-ui/react-tabs": "^1.1.13",
    "@radix-ui/react-tooltip": "^1.2.8",
    "@scure/base": "^1.2.6",
    "@scure/bip32": "^1.7.0",
    "@scure/bip39": "^1.6.0",
    "@walletconnect/core": "^2.21.0",
    "@walletconnect/modal": "^2.7.0",
    "@walletconnect/sign-client": "^2.21.0",
    "@walletconnect/types": "^2.21.0",
    "@walletconnect/utils": "^2.21.0",
    "abitype": "^1.1.0",
    "argon2": "^0.44.0",
    "base64-js": "^1.5.1",
    "bn.js": "^5.2.2",
    "buffer": "^6.0.3",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "concurrently": "^8.0.0",
    "eventemitter3": "^5.0.1",
    "isows": "^1.0.7",
    "lucide-react": "^0.453.0",
    "next-themes": "^0.4.6",
    "node-gyp-build": "^4.8.4",
    "ox": "^0.9.6",
    "react": "^19.2.1",
    "react-dom": "^19.2.1",
    "rpc-websockets": "^9.1.3",
    "sonner": "^2.0.7",
    "tailwind-merge": "^3.3.1",
    "tailwindcss-animate": "^1.0.7",
    "tw-animate-css": "^1.4.0",
    "viem": "^2.43.1",
    "ws": "^8.18.0"
  },
  "devDependencies": {
    "@tailwindcss/typography": "^0.5.15",
    "@tailwindcss/vite": "^4.1.3",
    "@types/bn.js": "^5.2.0",
    "@types/node": "^20.0.0",
    "@types/react": "^19.2.1",
    "@types/react-dom": "^19.2.1",
    "@vitejs/plugin-react": "^5.0.4",
    "electron": "^28.0.0",
    "electron-builder": "^24.6.0",
    "jsdom": "^25.0.1",
    "postcss": "^8.4.47",
    "prettier": "^3.6.2",
    "tailwindcss": "^4.1.14",
    "typescript": "5.9.3",
    "vite": "^5.0.0",
    "vitest": "^2.1.4"
  },
  "main": "electron/main-wrapper.js",
  "homepage": "./",
  "build": {
    "appId": "com.chunknet.desktop",
    "productName": "Chunknet",
    "asar": true,
    "asarUnpack": [
      "node_modules/argon2/**/*",
      "node_modules/node-gyp-build/**/*"
    ],
    "directories": { "output": "release" },
    "files": [
      "dist/public/**/*",
      "electron/**/*",
      "server/**/*",
      "build/installer.nsh",
      "package.json"
    ],
    "extraMetadata": { "main": "electron/main-wrapper.js" },
    "win": { "target": ["nsis"], "icon": "assets/icon.ico" },
    "nsis": {
      "oneClick": false,
      "perMachine": false,
      "allowToChangeInstallationDirectory": true,
      "deleteAppDataOnUninstall": false,
      "include": "build/installer.nsh"
    }
  }
}
